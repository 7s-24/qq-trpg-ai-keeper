# NoneBot / QQ 官方 Bot 配置（本地优先 WebSocket）
DRIVER=~websockets+~httpx
HOST=127.0.0.1
PORT=8080
COMMAND_START=["."]

# QQ 官方 Bot 凭据，请从 QQ 开放平台获取
QQ_BOTS='[{"id":"your_app_id","token":"your_token","secret":"your_secret","intent":{"guild_messages":true,"at_messages":true,"direct_message":true}}]'

# 机器人超级用户，逗号分隔 QQ 号
TRPG_SUPERUSERS=123456789
# 可选：默认 KP，逗号分隔 QQ 号
TRPG_DEFAULT_KPS=

# 数据与 AI
TRPG_DATA_DIR=data
TRPG_DATABASE_PATH=data/trpg.sqlite3
TRPG_DEFAULT_REPLY_MODE=manual
TRPG_DEFAULT_RULE_SYSTEM=COC7

# OpenAI-compatible API（不要提交真实 Key）
TRPG_AI_BASE_URL=https://api.openai.com/v1
TRPG_AI_API_KEY=
TRPG_AI_MODEL=gpt-4o-mini
TRPG_AI_TIMEOUT_SECONDS=60
